{
  "info": {
    "name": "BookForum - Users (CR2 / CR11)",
    "description": "GET / PUT / DELETE de usuario. Usa {{userId}} capturado no Register/Login.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "https://bookforum.vgrn.cloud" }
  ],
  "item": [
    {
      "name": "Get by id (GET /api/users/{id}) -> 200",
      "request": {
        "method": "GET",
        "header": [ { "key": "Authorization", "value": "Bearer {{token}}" } ],
        "url": { "raw": "{{baseUrl}}/api/users/{{userId}}", "host": ["{{baseUrl}}"], "path": ["api","users","{{userId}}"] }
      }
    },
    {
      "name": "Update (PUT /api/users/{id}) -> 200",
      "request": {
        "method": "PUT",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "url": { "raw": "{{baseUrl}}/api/users/{{userId}}", "host": ["{{baseUrl}}"], "path": ["api","users","{{userId}}"] },
        "body": { "mode": "raw", "raw": "{\n  \"username\": \"demo_user\",\n  \"email\": \"demo@bookforum.com\",\n  \"bio\": \"Atualizado ao vivo\"\n}" },
        "description": "ATENCAO: o update sobrescreve username/email com o body. Por isso mando os 3 campos; so a bio zeraria username/email."
      }
    },
    {
      "name": "Delete (DELETE /api/users/{id}) -> 204",
      "request": {
        "method": "DELETE",
        "header": [ { "key": "Authorization", "value": "Bearer {{token}}" } ],
        "url": { "raw": "{{baseUrl}}/api/users/{{userId}}", "host": ["{{baseUrl}}"], "path": ["api","users","{{userId}}"] }
      }
    }
  ]
}
