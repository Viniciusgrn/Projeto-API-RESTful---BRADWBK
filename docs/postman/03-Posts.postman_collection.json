{
  "info": {
    "name": "BookForum - Posts (CR3 / CR11)",
    "description": "Create / Feed / Delete de post. Create salva {{postId}} automaticamente.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "https://bookforum.vgrn.cloud" }
  ],
  "item": [
    {
      "name": "Create (POST /api/posts) -> 200",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const b = pm.response.json();",
              "if (b.id) { pm.environment.set('postId', b.id); console.log('postId =', b.id); }"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "url": { "raw": "{{baseUrl}}/api/posts", "host": ["{{baseUrl}}"], "path": ["api","posts"] },
        "body": { "mode": "raw", "raw": "{\n  \"userId\": 1,\n  \"bookTitle\": \"1984\",\n  \"bookAuthor\": \"George Orwell\",\n  \"content\": \"Otimo livro.\"\n}" }
      }
    },
    {
      "name": "Feed (GET /api/posts/feed?userId=1) -> 200",
      "request": {
        "method": "GET",
        "header": [ { "key": "Authorization", "value": "Bearer {{token}}" } ],
        "url": {
          "raw": "{{baseUrl}}/api/posts/feed?userId=1",
          "host": ["{{baseUrl}}"], "path": ["api","posts","feed"],
          "query": [ { "key": "userId", "value": "1" } ]
        }
      }
    },
    {
      "name": "Delete (DELETE /api/posts/{id}?userId=1) -> 204",
      "request": {
        "method": "DELETE",
        "header": [ { "key": "Authorization", "value": "Bearer {{token}}" } ],
        "url": {
          "raw": "{{baseUrl}}/api/posts/{{postId}}?userId=1",
          "host": ["{{baseUrl}}"], "path": ["api","posts","{{postId}}"],
          "query": [ { "key": "userId", "value": "1" } ]
        }
      }
    }
  ]
}
