{
  "info": {
    "name": "BookForum - Messages (CR5 / CR11)",
    "description": "Create / Conversation de mensagens.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "https://bookforum.vgrn.cloud" }
  ],
  "item": [
    {
      "name": "Create (POST /api/messages) -> 201",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "url": { "raw": "{{baseUrl}}/api/messages", "host": ["{{baseUrl}}"], "path": ["api","messages"] },
        "body": { "mode": "raw", "raw": "{\n  \"senderId\": 1,\n  \"receiverId\": 2,\n  \"content\": \"Ola, demonstracao ao vivo!\"\n}" }
      }
    },
    {
      "name": "Conversation (GET /api/messages/conversation/{a}/{b}) -> 200",
      "request": {
        "method": "GET",
        "header": [ { "key": "Authorization", "value": "Bearer {{token}}" } ],
        "url": {
          "raw": "{{baseUrl}}/api/messages/conversation/1/2",
          "host": ["{{baseUrl}}"], "path": ["api","messages","conversation","1","2"]
        }
      }
    }
  ]
}
